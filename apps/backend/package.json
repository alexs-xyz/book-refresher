{
  "name": "@book-refresher/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @book-refresher/shared-types build && tsx watch src/index.ts",
    "build": "pnpm --filter @book-refresher/shared-types build && tsc -p tsconfig.build.json",
    "start": "pnpm --filter @book-refresher/shared-types build && tsx src/index.ts",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@book-refresher/shared-types": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
